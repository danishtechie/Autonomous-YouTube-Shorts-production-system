# ============================================================
# YouTube Shorts Automation Bot - Environment Configuration
# ============================================================
# Copy this file to .env and fill in all values before running

# --- LLM API (Claude / OpenAI) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OR use OpenAI:
# OPENAI_API_KEY=your_openai_api_key_here
LLM_PROVIDER=anthropic          # anthropic | openai
LLM_MODEL=claude-3-5-haiku-20241022   

# --- Text-to-Speech ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel voice (professional female)
# Alternatives: EXAVITQu4vr4xnSDxMaL (Bella), ErXwobaYiN019PkySvjV (Antoni)

# --- Stock Footage ---
PEXELS_API_KEY=your_pexels_api_key_here
PIXABAY_API_KEY=your_pixabay_api_key_here

# --- YouTube Data API ---
YOUTUBE_CLIENT_ID=your_google_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_google_oauth_client_secret
YOUTUBE_REFRESH_TOKEN=your_oauth_refresh_token   
YOUTUBE_CHANNEL_ID=your_channel_id_here

# --- Reddit API (for trend detection) ---
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT= 

# --- Optional: SerpAPI for Google Trends ---
SERPAPI_KEY=your_serpapi_key_here

# --- System Settings ---
VIDEOS_PER_DAY=2
UPLOAD_TIMES=09:00,17:00        
NICHE=facts                    # facts | science | history | psychology | finance | motivation
MAX_VIDEO_DURATION=58          
MIN_VIDEO_DURATION=30

# --- Output Paths ---
OUTPUT_DIR=./output
LOGS_DIR=./logs
DB_PATH=./data/bot.db

# --- Retry Settings ---
MAX_RETRIES=3
RETRY_DELAY=30              
